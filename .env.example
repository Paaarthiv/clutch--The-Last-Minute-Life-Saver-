# Required for Gemini API calls.
GEMINI_API_KEY=your_gemini_api_key

# Optional. Cloud Run deploy sets this explicitly for the hackathon demo.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Enables Google Calendar sync in the browser.
GOOGLE_CALENDAR_CLIENT_ID=your_google_oauth_client_id

# Optional local fallback for Vite/browser-only config.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Optional runtime URL for deployed environments.
APP_URL=https://your-cloud-run-url.run.app
